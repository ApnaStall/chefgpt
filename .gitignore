# ================================
# RecipAI — .gitignore
# React + Python Flask + MySQL
# ================================

# ──────────────────────────────────
# Environment & Secrets
# ──────────────────────────────────
.env
.env.*
!.env.example
*.local

# ──────────────────────────────────
# Python / Flask (Backend)
# ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/
.virtualenv/

# Flask
instance/
.webassets-cache
flask_session/

# Coverage & testing
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
coverage.xml
*.cover

# Mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ──────────────────────────────────
# Node / React (Frontend)
# ──────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build output
frontend/dist/
frontend/build/
frontend/.vite/

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Storybook
storybook-static/

# ──────────────────────────────────
# Database
# ──────────────────────────────────
*.sql.bak
*.db
*.sqlite
*.sqlite3
mysql-data/
db_data/
dumps/

# ──────────────────────────────────
# Logs
# ──────────────────────────────────
*.log
logs/
*.log.*
pip-log.txt
pip-delete-this-directory.txt

# ──────────────────────────────────
# OS & Editor
# ──────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains / PyCharm
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Emacs
*.swp
*.swo
*.swn
.#*
\#*#

# ──────────────────────────────────
# Misc
# ──────────────────────────────────
*.bak
*.tmp
*.temp
.history/
.turbo/